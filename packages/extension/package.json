{
  "name": "fascinator",
  "displayName": "Fascinator",
  "description": "Multi-user, multi-cursor collaborative file editing for Dev Spaces",
  "version": "0.1.0",
  "publisher": "chapeaux",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Other"],
  "extensionKind": ["workspace"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fascinator.shareFile",
        "title": "Fascinator: Share This File"
      },
      {
        "command": "fascinator.copyShareLink",
        "title": "Fascinator: Copy Share Link"
      },
      {
        "command": "fascinator.removeGuest",
        "title": "Fascinator: Remove Guest"
      },
      {
        "command": "fascinator.listGuests",
        "title": "Fascinator: List Guests"
      },
      {
        "command": "fascinator.leaveSession",
        "title": "Fascinator: Leave Session"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fascinator",
          "title": "Fascinator",
          "icon": "$(people)"
        }
      ]
    },
    "views": {
      "fascinator": [
        {
          "id": "fascinator.presence",
          "name": "Collaborators"
        }
      ]
    },
    "configuration": {
      "title": "Fascinator",
      "properties": {
        "fascinator.serverUrl": {
          "type": "string",
          "default": "ws://localhost:3078",
          "description": "WebSocket URL of the Fascinator collaboration server"
        }
      }
    }
  },
  "scripts": {
    "compile": "webpack --mode development",
    "package": "webpack --mode production && vsce package --no-dependencies",
    "watch": "webpack --mode development --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^2.22.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "lib0": "^0.2.0",
    "y-protocols": "^1.0.0",
    "yjs": "^13.6.0"
  }
}
